{
  "id": "one_card",
  "kind": "single_card",
  "name": "Lectura de una Carta",
  "description": "Una reflexión enfocada en una pregunta, un tema o la energía actual.",
  "cardCount": 1,
  "ui": {
    "route": "/readings/one-card",
    "layout": "single_center_card",
    "saveToHistory": true,
    "canJournal": true
  },
  "positions": [
    {
      "id": "situation",
      "name": "Situación",
      "meaningPath": "positions.situation.{readingType}",
      "fallbackMeaningPath": "meanings.{readingType}.summary"
    }
  ],
  "template": {
    "opening": "Esta lectura de una carta concentra el mensaje en una reflexión sencilla.",
    "cardLine": "Para tu lectura de {readingTypeName}, {cardName} sugiere: {positionMeaning}",
    "adviceLine": "El consejo es: {advice}",
    "journalPromptLine": "Reflexión: {journalPrompt}",
    "closing": "Solo para reflexión y entretenimiento. No es consejo médico, legal, financiero ni profesional."
  },
  "supportedReadingTypes": [
    "general",
    "love",
    "career",
    "money",
    "growth"
  ],
  "drawPolicy": {
    "allowReversed": false,
    "avoidDuplicateCardsInSameReading": true
  },
  "safety": {
    "showDisclaimerKey": "standard_reflection_disclaimer"
  }
}